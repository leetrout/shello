root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.md]
# Preserve markdown hard line breaks (two trailing spaces)
trim_trailing_whitespace = false

[*.{json,jsonc,yaml,yml,toml}]
indent_style = space
indent_size = 2
